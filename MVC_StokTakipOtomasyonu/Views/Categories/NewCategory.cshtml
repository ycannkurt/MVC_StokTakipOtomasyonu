
@{
    ViewBag.Title = "NewCategory";
    Layout = "~/Views/Shared/_Layout.cshtml";
}




<div class="container">
    <div class="about-heading-content">
        <div class="row">
            <div class="col-xl-9 col-lg-10 mx-auto">
                <div class="bg-faded rounded p-5">
                    <h2 class="section-heading mb-4">
                        <span class="section-heading-upper"></span>
                        <span class="section-heading-lower">Kategori Ekleme</span>
                    </h2>

                    <div class="container">
                        <form action="/Categories/NewCategoryAction/">
                            <div class="form-group">
                                <label>Kategori</label>
                                <input type="text" name="Kategori" class="form-control" />
                            </div>
                            <div class="form-group">
                                <label>Açıklama</label>
                                <textarea name="Aciklama" class="form-control"></textarea>
                            </div>
                            <div class="form-group">
                                <button class="btn btn-success">Kategori Ekle</button>

                            </div>

                        </form>
                    </div>


                </div>
            </div>
        </div>
    </div>
</div>