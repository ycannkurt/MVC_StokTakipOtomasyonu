@model MVC_StokTakipOtomasyonu.Models.Entity.Kategoriler
@{
    ViewBag.Title = "GetUpdateInfo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="container">
    
    <div class="about-heading-content">
        <div class="row">
            <div class="col-xl-9 col-lg-10 mx-auto">
                <div class="bg-faded rounded p-5">
                    <h2 class="section-heading mb-4">
                        <span class="section-heading-upper"></span>
                        <span class="section-heading-lower">Veri Güncelle</span>
                    </h2>

                    <form action="/Categories/Update/">
                        @*<div class="form-group">
                            <b>ID</b>
                            @Html.TextBoxFor(x => x.ID, new { @class = "form-control" })
                        </div>*@
                        @Html.HiddenFor(x => x.ID)
                        <div class="form-group">
                            <b>Kategori</b>
                            @Html.TextBoxFor(x => x.Kategori, new { @class = "form-control" })
                        </div>

                        <div class="form-group">
                            <b>Açıklama</b>
                            @Html.TextBoxFor(x => x.Aciklama, new { @class = "form-control" })
                        </div>
                        <div><button class="btn btn-primary">Kategori Güncelle</button></div>
                    </form>
                </div>

                </div>
            </div>
        </div>
    </div>
</div>